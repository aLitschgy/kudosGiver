{
  "manifest_version": 2,
  "name": "Kudos Giver",
  "version": "1.1",
  "description": "This extension automates the process of giving kudos to your friends on Strava.",
  "permissions": ["tabs", "storage", "activeTab", "webNavigation"],
  "browser_specific_settings": {
    "gecko": {
      "id": "kudos-giver@litschgy.fr",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "browser_action": {
    "default_popup": "popup/kudos.html",
    "default_icon": {
      "32": "icons/kudo-32.png",
      "48": "icons/kudo-48.png",
      "96": "icons/kudo-96.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.strava.com/dashboard*"],
      "js": ["content_script/kudos.js"]
    }
  ]
}
